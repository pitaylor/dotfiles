#!/usr/bin/env bash

kasa=~/.venvs/kasa/bin/kasa

# Disabled for now
#plug_address="<put-ip-address-here>"

if [ -z "${plug_address}" ]; then
  echo "Error: plug_address is not defined or is empty" >&2
  exit 1
fi

if [ ! -f ~/.venvs/kasa/python3 ]; then
  mkdir -p ~/.venvs/kasa
  python3 -mvenv --prompt kasa ~/.venvs/kasa
fi

if [ ! -f ${kasa} ]; then
  ~/.venvs/kasa/bin/pip install python-kasa[speedups]
fi

${kasa} --type plug --host ${plug_address} "${@}"
